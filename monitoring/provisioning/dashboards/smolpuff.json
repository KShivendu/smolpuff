{
  "annotations": { "list": [] },
  "title": "SmolPuff",
  "uid": "smolpuff",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Write Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(store_operations_total{operation=\"upsert\"}[30s]))",
          "legendFormat": "upsert ops/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Query Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(store_operations_total{operation=\"query\"}[30s]))",
          "legendFormat": "query ops/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 3,
      "title": "Write Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(store_operation_duration_seconds_bucket{operation=\"upsert\"}[30s])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(store_operation_duration_seconds_bucket{operation=\"upsert\"}[30s])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(store_operation_duration_seconds_bucket{operation=\"upsert\"}[30s])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 4,
      "title": "Query Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(store_operation_duration_seconds_bucket{operation=\"query\"}[30s])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(store_operation_duration_seconds_bucket{operation=\"query\"}[30s])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(store_operation_duration_seconds_bucket{operation=\"query\"}[30s])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Writes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(increase(store_operations_total{operation=\"upsert\"}[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "Total Queries",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(increase(store_operations_total{operation=\"query\"}[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 7,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(store_operations_total{status=\"error\"}[5m])) / sum(rate(store_operations_total[5m])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "id": 8,
      "title": "Avg Write Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(store_operation_duration_seconds_sum{operation=\"upsert\"}[30s])) / sum(rate(store_operation_duration_seconds_count{operation=\"upsert\"}[30s]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 9,
      "title": "Avg Query Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(store_operation_duration_seconds_sum{operation=\"query\"}[30s])) / sum(rate(store_operation_duration_seconds_count{operation=\"query\"}[30s]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ],
  "schemaVersion": 39
}
